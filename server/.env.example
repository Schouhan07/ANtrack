PORT=5000
NODE_ENV=development
# Optional: browser origin when API is on a different host (e.g. https://app.example.com). Omit for same-origin.
# CLIENT_ORIGIN=https://app.example.com
MONGODB_URI=mongodb://localhost:27017/influencer_tracker
APIFY_TOKEN=your_apify_token_here
APIFY_TIKTOK_ACTOR_ID=clockworks~tiktok-scraper
APIFY_INSTAGRAM_ACTOR_ID=apify~instagram-scraper
# Instagram: max posts/comments per direct URL (default 1). Keeps pay-per-result cost low for reel/post links.
# INSTAGRAM_SCRAPER_RESULTS_LIMIT=1
# Optional JSON merged into actor input (e.g. includeComments:false on a fork). directUrls always comes from the app.
# INSTAGRAM_SCRAPER_EXTRA_INPUT={"includeComments":false,"includeRelatedPosts":false}
# Optional: max URLs per Apify actor run (default 100). Increase only if your actor allows it.
# APIFY_URLS_PER_RUN=100
